# Groq API -- get free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# HashKey Chain Mainnet RPC (Chain ID: 177)
HASHKEY_RPC=https://mainnet.hsk.xyz

# HashMind.sol contract address -- populated by contract/deploy.py
CONTRACT_ADDRESS=0x_deployed_hashmind_contract_address

# Deployer private key -- only needed for contract deployment & real on-chain logging
# NEVER commit a real key. Export from MetaMask: Account Details -> Export Private Key
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here
